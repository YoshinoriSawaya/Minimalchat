# --- Rust (wasm-image-processor) ---
# Rustのビルド成果物（treeで確認できた巨大なtargetディレクトリを除外）
**/target/

# --- .NET (backend) ---
# C#のコンパイル済みバイナリと一時ファイル
[Bb]in/
[Obj]/
# treeに見える Debug/net10.0 などを網羅
backend/bin/
backend/obj/

# --- Node.js / Frontend (frontend) ---
# 依存パッケージ（treeで非常に深い階層を確認）
node_modules/
# Vite等のビルド成果物
frontend/dist/
# 開発中のキャッシュ
.eslintcache

# --- Editor / IDE ---
# VS Codeの設定（プロジェクト共有の設定以外）
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
# IntelliJ / Rider
.idea/

# --- OS Specific ---
.DS_Store
Thumbs.db

# --- SQLite DB
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
backend/minimalchat.db
